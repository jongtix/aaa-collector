#!/bin/sh
# Pre-push hook: PMD + Tests
# Formatting → pre-commit, SpotBugs → CI

echo "[pre-push] Running PMD and tests..."

if ! ./gradlew pmdMain pmdTest test --daemon --quiet; then
    echo "[pre-push] PMD or tests failed. Fix issues before pushing."
    exit 1
fi

echo "[pre-push] All checks passed."
