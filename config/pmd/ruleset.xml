<?xml version="1.0"?>
<ruleset name="aaa-collector"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>aaa-collector PMD rules</description>

    <!-- Best Practices -->
    <rule ref="category/java/bestpractices.xml">
        <exclude name="UnitTestAssertionsShouldIncludeMessage"/>
    </rule>

    <!-- Error Prone -->
    <rule ref="category/java/errorprone.xml">
        <exclude name="MissingSerialVersionUID"/>
        <exclude name="AvoidDuplicateLiterals"/>
    </rule>
    <rule ref="category/java/errorprone.xml/AvoidDuplicateLiterals">
        <properties>
            <property name="skipAnnotations" value="true"/>
            <!-- 테스트 클래스에서는 픽스처/어서션 리터럴 반복이 자연스러우므로 제외 -->
            <property name="violationSuppressXPath"
                      value="//ClassDeclaration[ends-with(@SimpleName, 'Test')]"/>
        </properties>
    </rule>

    <!-- Code Style (노이즈가 많은 룰 제외) -->
    <rule ref="category/java/codestyle.xml">
        <exclude name="MethodArgumentCouldBeFinal"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="AtLeastOneConstructor"/>
        <exclude name="ShortVariable"/>
        <exclude name="LongVariable"/>
        <!-- 팩토리 메서드 관례(Optional.of, Set.of 등)와 동일한 짧은 메서드명 허용 -->
        <exclude name="ShortMethodName"/>
        <!-- package-private은 Java 언어 수준에서 명시적. Spotless와 충돌하므로 주석 강제 불필요 -->
        <exclude name="CommentDefaultAccessModifier"/>
        <!-- SLF4J 관례: private static final Logger log = ... -->
        <exclude name="FieldNamingConventions"/>
    </rule>
    <rule ref="category/java/codestyle.xml/FieldNamingConventions">
        <properties>
            <property name="constantPattern" value="[A-Z][A-Z_0-9]*|log"/>
        </properties>
    </rule>

    <!-- Design -->
    <rule ref="category/java/design.xml">
        <exclude name="LawOfDemeter"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="DataClass"/>
        <exclude name="TooManyMethods"/>
    </rule>
    <rule ref="category/java/design.xml/TooManyMethods">
        <properties>
            <property name="maxmethods" value="20"/>
        </properties>
    </rule>

    <!-- Multithreading -->
    <rule ref="category/java/multithreading.xml">
        <exclude name="DoNotUseThreads"/>
    </rule>

    <!-- Performance -->
    <rule ref="category/java/performance.xml"/>

    <!-- Custom Rules -->
    <!-- Virtual Threads 환경에서 fixedDelay/fixedDelayString 사용 금지 (Spring Framework #31900, #31749) -->
    <rule name="NoFixedDelayScheduled"
          language="java"
          message="@Scheduled에 fixedDelay/fixedDelayString 사용 금지 — Virtual Threads 버그 (Spring Framework #31900, #31749). cron 표현식을 사용하세요."
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>
            Virtual Threads 환경에서 @Scheduled(fixedDelay=...)는 타이밍 버그를 유발할 수 있다.
            모든 @Scheduled 작업은 cron 표현식만 사용한다.
        </description>
        <priority>1</priority>
        <properties>
            <property name="xpath">
                <value>
                    <![CDATA[
                    //Annotation[SimpleName/@Image='Scheduled']//MemberValuePair[@MemberName='fixedDelay' or @MemberName='fixedDelayString']
                    ]]>
                </value>
            </property>
        </properties>
    </rule>

</ruleset>
