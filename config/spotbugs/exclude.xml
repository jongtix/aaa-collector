<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        MaskingLevel.mdcKeys: Set.of()로 생성된 불변 집합을 반환하므로 실제 노출 위험 없음.
        SpotBugs가 반환 타입(Set)만 보고 오탐할 경우 대비.
    -->
    <Match>
        <Class name="com.aaa.collector.common.logging.MaskingLevel"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: Spring DI 생성자 주입 패턴.
        싱글톤 Bean을 final 필드에 저장하는 표준 패턴이며, 방어적 복사가 불필요.
        kis.token 패키지의 모든 Spring Bean에 적용.
    -->
    <Match>
        <Package name="com.aaa.collector.kis.token"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        KisProperties: @ConfigurationProperties record.
        Spring Boot가 불변 리스트로 바인딩하므로 accounts() 반환값은 실제 mutable 아님.
    -->
    <Match>
        <Class name="com.aaa.collector.kis.token.KisProperties"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!--
        KisGroupListResponse / KisStockListByGroupResponse: Jackson 역직렬화 전용 record.
        output2 필드는 Jackson이 외부 JSON에서 채우는 읽기 전용 DTO이며, 방어적 복사 불필요.
    -->
    <Match>
        <Class name="com.aaa.collector.watchlist.KisGroupListResponse"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="com.aaa.collector.watchlist.KisStockListByGroupResponse"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: Spring DI 생성자 주입 패턴 (kis.token과 동일).
        WebSocketClient, MessageHandler 등 싱글톤/세션 객체를 final 필드에 저장하는 표준 패턴.
    -->
    <Match>
        <Package name="com.aaa.collector.kis.websocket"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: Spring DI 생성자 주입 패턴 (kis.token/kis.websocket과 동일).
        RestClient, JpaRepository, MarketIndicatorSourceChain 등 싱글톤 Bean을
        final 필드에 저장하는 표준 패턴이며, 방어적 복사가 불필요·불가능.
        (SPEC-COLLECTOR-MARKETIND-001, user-approved 2026-06-20)
    -->
    <Match>
        <Package name="com.aaa.collector.market.indicator"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="com.aaa.collector.market.indicator.usdkrw"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="com.aaa.collector.market.indicator.vix"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: Spring DI 생성자 주입 패턴 (kis.token/kis.websocket과 동일).
        MarketSessionGate/UsMarketSessionGate가 expected_watermark 게이지를 REQ-WM-008/009에 따라
        조건부로 등록/해제(unregister)하려면 MeterRegistry를 필드로 보유해야 한다(생성자 스코프 한정
        사용 불가). 싱글턴 Bean을 final 필드에 저장하는 표준 패턴이며 방어적 복사가 불필요.
        (SPEC-OBSV-WATERMARK-001, user-approved 2026-07-05)
    -->
    <Match>
        <Package name="com.aaa.collector.market.session"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        CIPHER_INTEGRITY / PADDING_ORACLE: KIS Open API 프로토콜 강제 사양.
        KIS WebSocket은 AES-256-CBC + PKCS5Padding을 서버가 지정하므로 알고리즘 변경 불가.
        외부 네트워크에서 수신한 암호문을 신뢰 채널(KIS 서버 직접 연결)에서만 처리함.
    -->
    <Match>
        <Class name="com.aaa.collector.kis.websocket.KisAesDecryptor"/>
        <Bug pattern="CIPHER_INTEGRITY,PADDING_ORACLE"/>
    </Match>

    <!--
        테스트 암호화 헬퍼(encryptForTest, encrypt): KIS 프로토콜 테스트 벡터 생성 목적.
        프로덕션 코드가 아니며, 고정 IV(STATIC_IV)도 테스트 재현성을 위한 의도적 설계.
    -->
    <Match>
        <Class name="com.aaa.collector.kis.websocket.KisAesDecryptorTest"/>
        <Bug pattern="CIPHER_INTEGRITY,PADDING_ORACLE,STATIC_IV"/>
    </Match>
    <Match>
        <Class name="com.aaa.collector.kis.websocket.KisWebSocketMessageHandlerTest"/>
        <Bug pattern="CIPHER_INTEGRITY,PADDING_ORACLE,STATIC_IV"/>
    </Match>

    <!--
        DMI_CONSTANT_DB_PASSWORD / HARD_CODE_PASSWORD: SharedMySqlContainer는
        SPEC-COLLECTOR-DBGRANT-003 M1-T1 테스트 인프라 전용 지원 클래스다. 여기서 연결에 쓰이는
        비밀번호는 이 클래스가 소유한 테스트 전용 고정 상수(FLYWAY_PASSWORD/COLLECTOR_PASSWORD)로,
        같은 테스트 실행 동안만 존재하는 일회성 Testcontainers MySQL 인스턴스의 계정이며 실제
        시크릿이 아니다. SpotBugs는 "하드코딩된 리터럴이 DB 연결에 쓰였다"는 패턴만 보고 이
        컨텍스트(컨테이너가 테스트 종료와 함께 폐기됨)를 구분하지 못하므로 이 클래스에 한해
        제외한다(showFlywayGrants/showGrantsFor — 자격증명이 클래스 밖으로 노출되지 않도록
        무인자 공개 메서드 + private 내부 메서드로 설계했으나, 상수 인라이닝으로 인해 SpotBugs가
        여전히 리터럴을 탐지한다). user-approved 2026-07-04, SPEC-COLLECTOR-DBGRANT-003.
    -->
    <Match>
        <Class name="com.aaa.collector.support.SharedMySqlContainer"/>
        <Bug pattern="DMI_CONSTANT_DB_PASSWORD,HARD_CODE_PASSWORD"/>
    </Match>

    <!--
        SQL_INJECTION_JDBC: Tier2GrantMigrationStrategy.applyTier2Grants(DataSource)는
        SPEC-COLLECTOR-DBGRANT-003 M2-T2 grant 순서 훅으로, Flyway migrate 직후 root
        커넥션으로 Tier-2 테이블에 UPDATE GRANT를 적용한다. GRANT 문의 테이블/스키마 식별자는
        JDBC 바인드 변수로 파라미터화할 수 없다(값이 아닌 식별자이므로 PreparedStatement 불가).
        여기 흐르는 동적 값은 두 가지뿐이다: (1) DbGrantVerifier.TIER2_TABLES — 외부 입력 경로가
        전혀 없는 5개 고정 상수 집합(DbGrantVerifierTest가 정확히 5개로 고정), (2) JDBC 커넥션
        자신의 catalog(schema)명 — Testcontainers가 결정하는 환경값이며 공격자가 제어할 수 없다.
        SharedMySqlContainer 항목(위)과 달리 이 항목은 의도적으로 클래스 전체가 아니라
        applyTier2Grants 메서드 하나로만 범위를 좁힌다 — 이 클래스에 향후 다른 SQL이 추가되면
        여전히 정상적으로 검사받도록 하기 위함이다. user-approved 2026-07-04,
        SPEC-COLLECTOR-DBGRANT-003.
    -->
    <Match>
        <Class name="com.aaa.collector.common.startup.Tier2GrantMigrationStrategy"/>
        <Method name="applyTier2Grants"/>
        <Bug pattern="SQL_INJECTION_JDBC"/>
    </Match>
</FindBugsFilter>
