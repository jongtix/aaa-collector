<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        MaskingLevel.mdcKeys: Set.of()로 생성된 불변 집합을 반환하므로 실제 노출 위험 없음.
        SpotBugs가 반환 타입(Set)만 보고 오탐할 경우 대비.
    -->
    <Match>
        <Class name="com.aaa.collector.common.logging.MaskingLevel"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: Spring DI 생성자 주입 패턴.
        싱글톤 Bean을 final 필드에 저장하는 표준 패턴이며, 방어적 복사가 불필요.
        kis.token 패키지의 모든 Spring Bean에 적용.
    -->
    <Match>
        <Package name="com.aaa.collector.kis.token"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        KisProperties: @ConfigurationProperties record.
        Spring Boot가 불변 리스트로 바인딩하므로 accounts() 반환값은 실제 mutable 아님.
    -->
    <Match>
        <Class name="com.aaa.collector.kis.token.KisProperties"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!--
        KisGroupListResponse / KisStockListByGroupResponse: Jackson 역직렬화 전용 record.
        output2 필드는 Jackson이 외부 JSON에서 채우는 읽기 전용 DTO이며, 방어적 복사 불필요.
    -->
    <Match>
        <Class name="com.aaa.collector.watchlist.KisGroupListResponse"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="com.aaa.collector.watchlist.KisStockListByGroupResponse"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: Spring DI 생성자 주입 패턴 (kis.token과 동일).
        WebSocketClient, MessageHandler 등 싱글톤/세션 객체를 final 필드에 저장하는 표준 패턴.
    -->
    <Match>
        <Package name="com.aaa.collector.kis.websocket"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: Spring DI 생성자 주입 패턴 (kis.token/kis.websocket과 동일).
        RestClient, JpaRepository, MarketIndicatorSourceChain 등 싱글톤 Bean을
        final 필드에 저장하는 표준 패턴이며, 방어적 복사가 불필요·불가능.
        (SPEC-COLLECTOR-MARKETIND-001, user-approved 2026-06-20)
    -->
    <Match>
        <Package name="com.aaa.collector.market.indicator"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="com.aaa.collector.market.indicator.usdkrw"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Package name="com.aaa.collector.market.indicator.vix"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        CIPHER_INTEGRITY / PADDING_ORACLE: KIS Open API 프로토콜 강제 사양.
        KIS WebSocket은 AES-256-CBC + PKCS5Padding을 서버가 지정하므로 알고리즘 변경 불가.
        외부 네트워크에서 수신한 암호문을 신뢰 채널(KIS 서버 직접 연결)에서만 처리함.
    -->
    <Match>
        <Class name="com.aaa.collector.kis.websocket.KisAesDecryptor"/>
        <Bug pattern="CIPHER_INTEGRITY,PADDING_ORACLE"/>
    </Match>

    <!--
        테스트 암호화 헬퍼(encryptForTest, encrypt): KIS 프로토콜 테스트 벡터 생성 목적.
        프로덕션 코드가 아니며, 고정 IV(STATIC_IV)도 테스트 재현성을 위한 의도적 설계.
    -->
    <Match>
        <Class name="com.aaa.collector.kis.websocket.KisAesDecryptorTest"/>
        <Bug pattern="CIPHER_INTEGRITY,PADDING_ORACLE,STATIC_IV"/>
    </Match>
    <Match>
        <Class name="com.aaa.collector.kis.websocket.KisWebSocketMessageHandlerTest"/>
        <Bug pattern="CIPHER_INTEGRITY,PADDING_ORACLE,STATIC_IV"/>
    </Match>
</FindBugsFilter>
