# =============================================================================
# aaa-collector — .env.collector 템플릿
# =============================================================================
#
# 이 파일은 collector 서비스 전용 환경 변수 템플릿이다.
# 프로덕션 배포 시 ${AAA_SSD_BASE}/secrets/.env.collector 로 복사하여 값을 채운다.
#
# 인프라 공통 변수(REDIS_HOST, REDIS_PORT, REDIS_APPUSER_PASSWORD, MYSQL_* 등)는
# .env.common에서 제공되므로 이 파일에 포함하지 않는다. (ADR-006 참조)
#
# 보안:
#   chmod 600 ${AAA_SSD_BASE}/secrets/.env.collector
#
# =============================================================================


# -----------------------------------------------------------------------------
# Flyway DB 계정 (DDL 전용, ADR-016 결정 3)
# -----------------------------------------------------------------------------

# .env.mysql의 MYSQL_FLYWAY_PASSWORD와 반드시 동일한 값이어야 한다
MYSQL_FLYWAY_PASSWORD=<openssl rand -hex 24>


# -----------------------------------------------------------------------------
# Collector DB 계정 (런타임 DML 전용)
# -----------------------------------------------------------------------------

# .env.mysql의 MYSQL_COLLECTOR_PASSWORD와 반드시 동일한 값이어야 한다
MYSQL_COLLECTOR_PASSWORD=<openssl rand -hex 24>


# -----------------------------------------------------------------------------
# KIS Open API
# -----------------------------------------------------------------------------

# 한국투자증권 Open API 베이스 URL
# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# 한국투자증권 MTS 사용자 ID — 관심 그룹/종목 조회 시 사용
KIS_USER_ID=<kis-mts-user-id>


# -----------------------------------------------------------------------------
# KIS 계좌별 자격증명 (5개 계좌)
# -----------------------------------------------------------------------------

# ISA중계형
KIS_ACCT_ISA_NUMBER=<account-number>
KIS_ACCT_ISA_APP_KEY=<app-key>
KIS_ACCT_ISA_APP_SECRET=<app-secret>

# 금 거래
KIS_ACCT_GOLD_NUMBER=<account-number>
KIS_ACCT_GOLD_APP_KEY=<app-key>
KIS_ACCT_GOLD_APP_SECRET=<app-secret>

# 연금저축
KIS_ACCT_PENSION_NUMBER=<account-number>
KIS_ACCT_PENSION_APP_KEY=<app-key>
KIS_ACCT_PENSION_APP_SECRET=<app-secret>

# 위탁계좌
KIS_ACCT_STOCK_NUMBER=<account-number>
KIS_ACCT_STOCK_APP_KEY=<app-key>
KIS_ACCT_STOCK_APP_SECRET=<app-secret>

# 퇴직연금DC
KIS_ACCT_DC_NUMBER=<account-number>
KIS_ACCT_DC_APP_KEY=<app-key>
KIS_ACCT_DC_APP_SECRET=<app-secret>


# -----------------------------------------------------------------------------
# 외부 API 키 (현재 미사용 — 해당 수집 기능 구현 시 활성화)
# -----------------------------------------------------------------------------

# 한국수출입은행 API — 환율 USDKRW Primary (TECHSPEC 3.4절)
# KOREAEXIM_API_KEY=<api-key>

# 한국은행 ECOS API — 한국 거시경제 + 환율 Fallback (TECHSPEC 3.4~3.5절)
# ECOS_API_KEY=<api-key>

# FRED API — 미국 거시경제 + VIX Fallback (TECHSPEC 3.4~3.5절)
# FRED_API_KEY=<api-key>

# DART OpenAPI — 한국 기업 공시 (TECHSPEC 3.5절)
# DART_API_KEY=<api-key>

# Alpaca Free API — Pre/After-Hours Fallback (TECHSPEC 3.4절)
# ALPACA_API_KEY=<api-key>
# ALPACA_API_SECRET=<api-secret>

# Polygon.io Free API — Pre/After-Hours Fallback (TECHSPEC 3.4절)
# POLYGON_API_KEY=<api-key>
